# alloul-agent environment variables
# Copy to .env and fill in your values

# Groq API — free 14,400 req/day
# Get key from: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use (default: llama-3.3-70b-versatile)
# Options: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Protect the API with a secret key
# If set, clients must send: X-Api-Key: your-secret
AGENT_API_KEY=

# Optional: Override the default Arabic system prompt
# AGENT_SYSTEM_PROMPT=أنت مساعد ذكي...
