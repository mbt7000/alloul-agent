[Unit]
Description=alloul-agent AI API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/alloul-agent
EnvironmentFile=/root/alloul-agent/.env
ExecStart=/root/alloul-agent/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8001 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
